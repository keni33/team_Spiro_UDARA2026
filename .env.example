# StructGuard AI — Environment Configuration
# ============================================
# HOW TO USE:
#   1. Copy this file: cp .env.example .env
#   2. Fill in your values below
#   3. NEVER commit .env to GitHub — it contains secrets
#
# Teaching note: Environment variables separate config from code.
# You can run the same code in development (SQLite) and production
# (PostgreSQL) just by changing these values.

# ─── SECURITY (MUST CHANGE IN PRODUCTION) ───────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-change-me-before-production
JWT_SECRET_KEY=jwt-secret-change-me-before-production

# ─── DATABASE ────────────────────────────────────────────────────────
# Development: uses SQLite (no install needed, file-based)
DATABASE_URL=sqlite:///structguard.db
# Production: use PostgreSQL (uncomment and fill in):
# DATABASE_URL=postgresql://user:password@localhost:5432/structguard_db

# ─── JWT TOKEN EXPIRY ────────────────────────────────────────────────
JWT_ACCESS_TOKEN_EXPIRES_HOURS=8     # Access token: 8 hours
JWT_REFRESH_TOKEN_EXPIRES_DAYS=30    # Refresh token: 30 days

# ─── FILE UPLOADS ────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=20                # Max size per image upload
ALLOWED_EXTENSIONS=jpg,jpeg,png,webp # Accepted image types

# ─── AI ANALYSIS ─────────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=
# Set to true to use demo/mock data instead of real AI (good for testing)
AI_DEMO_MODE=true

# ─── FRONTEND URL (for CORS) ─────────────────────────────────────────
# Where your frontend is served from. For VS Code Live Server: http://localhost:5500
FRONTEND_URL=http://localhost:5500

# ─── GOOGLE OAUTH (optional — for "Sign in with Google") ─────────────────────
# Step 1: Go to https://console.cloud.google.com
# Step 2: Create a project → APIs & Services → Credentials → OAuth 2.0 Client ID
# Step 3: Application type: Web application
# Step 4: Authorised redirect URI: http://localhost:5000/api/auth/google/callback
# Step 5: Copy the Client ID and Client Secret below
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback


# ─── GOOGLE OAUTH ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback
